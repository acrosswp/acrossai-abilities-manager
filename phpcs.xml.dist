<?xml version="1.0"?>
<ruleset name="AcrossAI Abilities Manager Coding Standards">
    <description>Coding standards for AcrossAI Abilities Manager</description>

    <!-- Check all PHP files in directory tree by default. -->
    <arg name="extensions" value="php"/>
    <file>.</file>

    <!-- Show progress and sniff codes in all reports -->
    <arg value="ps"/>

    <!-- Exclude paths -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>
    <exclude-pattern>*/.specify/*</exclude-pattern>
    <exclude-pattern>*/docs/*</exclude-pattern>
    <exclude-pattern>*/specs/*</exclude-pattern>
    <exclude-pattern>*/src/*</exclude-pattern>
    <exclude-pattern>*/.claude/*</exclude-pattern>
    <exclude-pattern>*/.agents/*</exclude-pattern>
    <exclude-pattern>*/.github/*</exclude-pattern>

    <!-- Include the WordPress-Extra standard. -->
    <rule ref="WordPress-Extra">
        <!-- Allow short array syntax -->
        <exclude name="Generic.Arrays.DisallowShortArraySyntax"/>

        <!-- Project uses PSR-4 PascalCase file naming, not WPCS kebab-case -->
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>

        <!-- Technical inline comments sometimes contain code-like syntax -->
        <exclude name="Squiz.PHP.CommentedOutCode.Found"/>

        <!-- Intentional method overrides for extension points and documentation -->
        <exclude name="Generic.CodeAnalysis.UselessOverridingMethod"/>

        <!-- Security blank files use // Silence is golden. (standard WP pattern) -->
        <exclude name="Squiz.Commenting.FileComment.WrongStyle"/>
    </rule>

    <!-- Let's also check that everything is properly documented. -->
    <rule ref="WordPress-Docs"/>

    <!-- Add in some extra rules from other standards. -->
    <rule ref="Generic.CodeAnalysis.UnusedFunctionParameter"/>
    <rule ref="Generic.Commenting.Todo"/>

    <!-- Allow plugin file header -->
    <rule ref="Squiz.Commenting.FileComment">
        <exclude-pattern>*/acrossai-abilities-manager.php</exclude-pattern>
    </rule>
</ruleset>
